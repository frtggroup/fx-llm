// Python: features.py BASE_FEATURE_COLS[37] = "stoch_k_21_5"
#ifndef FEAT_037_MQH
#define FEAT_037_MQH



double CalcFeat_037(
   const double &close[], const double &high[],
   const double &low[],  const double &open[],
   const double &vol[],  const int needed, const int i)
{

   // Stoch(21,5) k
   // fast K
   double hi=high[i],lo_val=low[i];
   for(int k=1;k<21&&i+k<needed;k++){hi=MathMax(hi,high[i+k]);lo_val=MathMin(lo_val,low[i+k]);}
   double fk=(close[i]-lo_val)/(hi-lo_val+1e-9);
   // smooth
   double sk=0; int sc=0;
   for(int j=0;j<5&&i+j<needed;j++){
      double h2=high[i+j],l2=low[i+j];
      for(int k2=1;k2<21&&i+j+k2<needed;k2++){h2=MathMax(h2,high[i+j+k2]);l2=MathMin(l2,low[i+j+k2]);}
      sk+=(close[i+j]-l2)/(h2-l2+1e-9); sc++;
   }
   return (sc>0)?sk/sc:fk;
}

#endif // FEAT_037_MQH
